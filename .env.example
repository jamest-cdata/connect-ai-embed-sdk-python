# Connect AI Embed SDK — Python
# Copy this file to .env and fill in your values.

# Your CData parent account ID (required)
CDATA_ACCOUNT_ID=your-parent-account-id

# Path to your RS256 private key PEM file (required)
CDATA_PRIVATE_KEY_PATH=privateKey.pem

# LLM provider for agent features: anthropic, openai, or gemini (optional)
# CDATA_LLM_PROVIDER=anthropic

# API key for your chosen LLM provider (optional — only needed for agent features)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# CData API URLs (optional — defaults are usually correct)
# CDATA_BASE_URL=https://cloud.cdata.com
# CDATA_QUERY_URL=https://cloud.cdata.com/api
# CDATA_MCP_URL=https://mcp.cloud.cdata.com/mcp

# Override the default LLM model (optional)
# CDATA_LLM_MODEL=claude-sonnet-4-5-20250929
